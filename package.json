{
	"name": "wine-app",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 3000",
		"start": "node .output/server/index.mjs",
		"build": "vite build",
		"serve": "vite preview",
		"test": "vitest run",
		"format": "biome format",
		"lint": "biome lint",
		"check": "biome check",
		"prepare": "husky"
	},
	"dependencies": {
		"@neondatabase/serverless": "^1.0.0",
		"@neondatabase/vite-plugin-postgres": "^0.2.0",
		"@tailwindcss/vite": "^4.0.6",
		"@tanstack/react-router": "^1.121.2",
		"@tanstack/react-router-devtools": "^1.121.2",
		"@tanstack/react-router-with-query": "^1.121.2",
		"@tanstack/react-start": "^1.121.2",
		"@tanstack/router-plugin": "^1.121.2",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"tailwindcss": "^4.0.6",
		"vite": "^6.3.3",
		"vite-tsconfig-paths": "^5.1.4"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@testing-library/dom": "^10.4.0",
		"@testing-library/react": "^16.2.0",
		"@types/react": "^19.0.8",
		"@types/react-dom": "^19.0.3",
		"@vitejs/plugin-react": "^4.3.4",
		"husky": "^9.1.7",
		"jsdom": "^26.0.0",
		"lint-staged": "^16.1.2",
		"typescript": "^5.7.2",
		"vite": "^6.1.0",
		"vitest": "^3.0.5",
		"web-vitals": "^4.2.4"
	},
	"lint-staged": {
		"src/**/*.{js,jsx,ts,tsx}": [
			"biome format --write --config-path=./biome.json",
			"biome lint --write --config-path=./biome.json"
		],
		"*.{js,ts}": ["biome format --write --config-path=./biome.json", "biome lint --write --config-path=./biome.json"],
		"*.json": ["biome format --write --config-path=./biome.json"]
	}
}
